# Copy this file to .env and fill in real values. Never commit .env itself.

# Sandbox: https://platform.devtest.ringcentral.com
# Production: https://platform.ringcentral.com
RC_SERVER_URL=https://platform.devtest.ringcentral.com

# From the RingCentral Developer Console, under your REST API App (Auth
# Type: JWT auth flow).
RC_CLIENT_ID=
RC_CLIENT_SECRET=

# Created under Console > your name (top right) > Credentials > Create JWT.
# Bound to a specific environment (sandbox vs prod) -- a sandbox JWT will
# not work against a production app, and vice versa.
RC_JWT=

# Where webhook_server.py forwards normalized events. Point this at the
# real CRM's inbound webhook URL in production; in this demo it points at
# crm_mock.py running locally.
CRM_WEBHOOK_URL=http://localhost:5001/crm-events
